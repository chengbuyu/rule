#!category=Surge去广告
#!date=2026-5-31 22:15:15

[Rule]
# 黑名单域名（精确匹配，每行一个）
DOMAIN-SET,https://cdn.jsdelivr.net/gh/VME98/jinx-rules@master/rules/blacklist.txt,REJECT-DROP
# 黑名单通配符规则
DOMAIN-SET,https://cdn.jsdelivr.net/gh/VME98/jinx-rules@master/rules/blacklist_wildcard.txt,REJECT-DROP
# 黑名单
DOMAIN-SET,https://cdn.jsdelivr.net/gh/VME98/jinx-rules@master/rules/domain_blacklist.txt,REJECT-DROP
# 白名单域名（精确匹配）
DOMAIN-SET,https://cdn.jsdelivr.net/gh/VME98/jinx-rules@master/rules/whitelist.txt,DIRECT
# 白名单通配符规则
DOMAIN-SET,https://cdn.jsdelivr.net/gh/VME98/jinx-rules@master/rules/whitelist_wildcard.txt,DIRECT
# 白名单
DOMAIN-SET,https://cdn.jsdelivr.net/gh/VME98/jinx-rules@master/rules/domain_whitelist.txt,DIRECT
